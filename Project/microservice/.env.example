# LLM
llm_provider=openai
llm_model=gpt-4o-mini
llm_base_url=https://api.openai.com/v1
llm_temperature=0.0
llm_timeout=30
openai_api_key=sk-your-openai-key

# Embeddings
embedding_provider=huggingface
embedding_model=all-MiniLM-L6-v2
embedding_dimensions=384

# Database (PostgreSQL Aiven Cloud)
database_url=postgresql+asyncpg://user:pass@host:port/dbname

# Paths
vectorstore_path=app/vectorstore/chroma
clinical_docs_path=app/data/clinical_docs
weights_path=app/data/optimized_weights.json
clinical_config_path=app/config/clinical_params.yaml

# LangSmith (tracing de agentes)
# Para activar: crear API key en https://smith.langchain.com → Settings → API Keys
# Sin key: el tracing se desactiva automaticamente (no bloquea el servicio)
langsmith_api_key=lsv2_pt_your_langsmith_api_key_here
langsmith_project=telemetry-heart-ai
langsmith_trace_v2=true

# Server
environment=dev
host=0.0.0.0
port=8001

# Security
internal_token=dev-token-cambiar-en-prod
