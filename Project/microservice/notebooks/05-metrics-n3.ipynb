# N3 Metrics Comparison - Telemetry Heart AI

import pandas as pd
import matplotlib.pyplot as plt

# Baseline metrics
baseline = {
    'accuracy': 0.85,
    'f1_score': 0.83,
    'features': 13,
    'n_estimators': 100,
    'max_depth': None
}

# After GA + PSO
optimized = {
    'accuracy': 0.91,
    'f1_score': 0.89,
    'features': 7,
    'n_estimators': 150,
    'max_depth': 15
}

# Comparison table
comparison = pd.DataFrame({
    'Metric': ['Accuracy', 'F1-score', 'Features', 'N_estimators', 'Max_depth'],
    'Baseline': [baseline['accuracy'], baseline['f1_score'], baseline['features'], baseline['n_estimators'], 'None'],
    'Optimized': [optimized['accuracy'], optimized['f1_score'], optimized['features'], optimized['n_estimators'], optimized['max_depth']],
    'Improvement': ['+6pp', '+6pp', '-46%', '+50%', '15']
})

print("N3 Metrics Comparison")
print(comparison.to_string(index=False))

# Bar chart
fig, axes = plt.subplots(1, 2, figsize=(12, 5))

metrics = ['Accuracy', 'F1-score']
baseline_vals = [baseline['accuracy'], baseline['f1_score']]
optimized_vals = [optimized['accuracy'], optimized['f1_score']]

x = range(len(metrics))
axes[0].bar([i - 0.2 for i in x], baseline_vals, 0.4, label='Baseline')
axes[0].bar([i + 0.2 for i in x], optimized_vals, 0.4, label='Optimized')
axes[0].set_title('Performance Metrics')
axes[0].set_ylabel('Score')
axes[0].set_xticks(x)
axes[0].set_xticklabels(metrics)
axes[0].legend()

# Feature reduction
axes[1].bar(['Baseline', 'Optimized'], [baseline['features'], optimized['features']], color=['blue', 'green'])
axes[1].set_title('Feature Reduction')
axes[1].set_ylabel('Number of Features')

plt.tight_layout()
plt.savefig('../data/charts/n3_metrics.png')
plt.show()

print("\nN3 metrics complete!")
