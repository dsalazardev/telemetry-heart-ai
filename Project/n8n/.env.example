# ── PostgreSQL (MISMA que el backend — compartida) ──
# Credenciales de Aiven Cloud (ver Project/backend/.env)
DB_POSTGRESDB_HOST=telemetry-heart-ai-ucaldas-80c3.g.aivencloud.com
DB_POSTGRESDB_PORT=10104
DB_POSTGRESDB_DATABASE=defaultdb
DB_POSTGRESDB_USER=avnadmin
DB_POSTGRESDB_PASSWORD=***
# SSL obligatorio para Aiven Cloud
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false

# ── n8n configuration ──
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_ENCRYPTION_KEY=***
# Seguridad y runners (requeridos en versiones recientes)
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_RUNNERS_ENABLED=true
# Logging
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console
# Zona horaria (obligatoria para schedulers)
GENERIC_TIMEZONE=America/Bogota
TZ=America/Bogota

# ── Telegram (bot que n8n usa para hablar con médicos) ──
# TELEGRAM_CHAT_ID no va aquí. Se obtiene de la tabla medicos.telegramChatId.
TELEGRAM_BOT_TOKEN=***

# ── LLM (interpreta preguntas del médico, genera SQL) ──
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-***
LLM_MODEL=gpt-4o-mini

# ── Backend API ──
BACKEND_URL=http://host.docker.internal:8000
BACKEND_API_KEY=***

# ── Microservicio LangChain ──
MICROSERVICE_URL=http://host.docker.internal:8001
