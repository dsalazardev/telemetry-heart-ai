        "query": "SELECT \n    t.id as triaje_id,\n    t.\"probabilidadRiesgo\",\n    t.\"nivelUrgencia\",\n    t.\"factoresCriticos\",\n    t.\"explicacionClinica\",\n    u.nombres as paciente_nombre,\n    u.apellidos as paciente_apellido\nFROM triajes t\nJOIN pacientes p ON t.paciente_id = p.id\nJOIN usuarios u ON p.id = u.id\nWHERE t.medico_id = {{ $('Identificar Medico').first().json.medico_id }}\n  AND t.paciente_id = {{ $('AI Agent').item.json.output }}",
