    {
      "parameters": {
        "jsCode": "const triajeIds = [];\nlet resumenPacientes = \"Lista de pacientes críticos pendientes:\\n\\n\";\n\n// Iterar sobre los resultados de la base de datos\nfor (const item of $input.all()) {\n  triajeIds.push(item.json.id);\n  resumenPacientes += `- Paciente: ${item.json.paciente_nombre} ${item.json.paciente_apellido}\\n`;\n  resumenPacientes += `  Urgencia: ${item.json.nivelurgencia} | Riesgo: ${item.json.probabilidadriesgo}%\\n`;\n  resumenPacientes += `  Teléfono: ${item.json.telefono}\\n\\n`;\n}\n\n// Retornamos un solo ítem con los IDs y el texto para la IA\nreturn {\n  triajeIds: triajeIds,\n  textoParaIA: resumenPacientes\n};"
      },
