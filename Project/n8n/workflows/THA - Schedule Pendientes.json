    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    t.id, \n    t.paciente_id, \n    t.\"probabilidadRiesgo\", \n    t.\"nivelUrgencia\", \n    t.\"fechaEmision\", \n    u.nombres as paciente_nombre, \n    u.apellidos as paciente_apellido, \n    u.telefono, \n    m.\"telegramChatId\" \nFROM triajes t \nJOIN pacientes p ON t.paciente_id = p.id \nJOIN usuarios u ON p.id = u.id  -- ¡Este es el JOIN que te faltaba!\nJOIN medicos m ON t.medico_id = m.id \nWHERE t.atendida = false \n  AND t.\"telegramEnviado\" = false \nORDER BY \n    CASE t.\"nivelUrgencia\" \n        WHEN 'Emergencia' THEN 1 \n        WHEN 'Urgente' THEN 2 \n        WHEN 'Alta' THEN 3 \n        WHEN 'Media' THEN 4 \n        ELSE 5 \n    END, \n    t.\"fechaEmision\" \nLIMIT 10",
        "options": {}
      },
      "name": "Triajes Pendientes",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [
